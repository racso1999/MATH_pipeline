from google import genai
import os
from dotenv import load_dotenv
from datasets import load_dataset
import time

# Load environment variables from .env file
load_dotenv()

# Load dataset
ds = load_dataset("HuggingFaceH4/MATH-500")
problems = ds["test"]

# Get the API key from environment variable
api_key = os.getenv("GOOGLE_API_KEY")
if not api_key:
    raise RuntimeError("api key missing")
client = genai.Client(api_key=api_key) # Initialize the GenAI client with the API key

# Define the model
model_name = "gemini-3.1-flash-lite"

correct = 0
total = 100

# Loop through the problems, generate answers, and compare with expected answers
answers = {}
for i, problem in enumerate(problems.select(range(total))):
    prompt = f"Solve this math problem. Give only the final answer.\n\n{problem['problem']}"

    try:
        response = client.models.generate_content(
            model=model_name,
            contents=prompt,
        )
    except Exception as e:
        print(f"{i+1}/{total} | API error with {model_name}: {e}")
        time.sleep(0.3)
        continue

    answer = (response.text or "")
    expected = problem["answer"]
    
    print(f"{i+1}/{total}")

    time.sleep(0.1)  # To avoid hitting rate limits
    answers[answer] = expected

#Evaluation using gemini flash lite
prompt = f"{[(k, v) for k, v in answers.items()]} For each answer, expected-answer pair: determine whether they are equivalent. Return in the format: 'i/total | Expected: expected | Answer: answer | ✓/✗'. Finally after a ! return the number of correct pairs as an integer"
response = client.models.generate_content(
            model="gemini-3.1-flash-lite",
            contents=prompt,
        )
reponses, correct = response.text.split("!")

print(f"Correct:\n{correct}/{total} \nDetails:\n{reponses}")

